{
  "name": "devpulse-ide",
  "displayName": "DevPulse IDE",
  "description": "Use DevPulse directly inside VS Code with project context and code insights.",
  "version": "0.1.0",
  "publisher": "devpulse",
  "license": "UNLICENSED",
  "preview": false,
  "keywords": [
    "devpulse",
    "api",
    "insights",
    "agent",
    "monitoring",
    "supabase"
  ],
  "galleryBanner": {
    "color": "#111827",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devpulse",
          "title": "DevPulse",
          "icon": "media/devpulse.svg"
        }
      ]
    },
    "views": {
      "devpulse": [
        {
          "id": "devpulse.sidebarView",
          "name": "Workspace Insights",
          "type": "webview"
        },
        {
          "id": "devpulseApiInventory",
          "name": "API Inventory",
          "icon": "$(list-unordered)"
        }
      ]
    },
    "commands": [
      {
        "command": "devpulse.openPanel",
        "title": "DevPulse: Open Full Panel"
      },
      {
        "command": "devpulse.sendEditorContext",
        "title": "DevPulse: Send Active Editor Context"
      },
      {
        "command": "devpulse.analyzeSelection",
        "title": "DevPulse: Analyze Selected Code"
      },
      {
        "command": "devpulse.copyContextAsMarkdown",
        "title": "DevPulse: Copy Context as Markdown"
      },
      {
        "command": "devpulse.openWebApp",
        "title": "DevPulse: Open Web App"
      },
      {
        "command": "devpulse.refresh",
        "title": "DevPulse: Refresh"
      },
      {
        "command": "devpulse.scanFile",
        "title": "DevPulse: Scan Current File for API Risks"
      },
      {
        "command": "devpulse.scanProject",
        "title": "DevPulse: Scan Project for Shadow APIs"
      },
      {
        "command": "devpulse.showDashboard",
        "title": "DevPulse: Show Security Dashboard"
      },
      {
        "command": "devpulse.showCompliance",
        "title": "DevPulse: Show Compliance Status"
      },
      {
        "command": "devpulse.authenticateBackend",
        "title": "DevPulse: Connect to Backend"
      },
      {
        "command": "devpulse.showStatus",
        "title": "DevPulse: Show Connection Status"
      },
      {
        "command": "devpulse.exportReport",
        "title": "DevPulse: Export Security Report"
      },
      {
        "command": "devpulse.openSettings",
        "title": "DevPulse: Settings"
      },
      {
        "command": "devpulse.quickFix",
        "title": "DevPulse: Quick Fix"
      },
      {
        "command": "devpulse.refreshInventory",
        "title": "DevPulse: Refresh API Inventory"
      }
    ],
    "configuration": {
      "title": "DevPulse",
      "properties": {
        "devpulse.webAppUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "DevPulse web app URL shown in the extension webview."
        },
        "devpulse.autoSyncEditorContext": {
          "type": "boolean",
          "default": true,
          "description": "Automatically send active file and selection updates to DevPulse."
        },
        "devpulse.maxSelectionChars": {
          "type": "number",
          "default": 12000,
          "minimum": 500,
          "maximum": 50000,
          "description": "Maximum number of characters sent for selected code."
        },
        "devpulse.apiEndpoint": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "DevPulse backend API endpoint URL"
        },
        "devpulse.apiToken": {
          "type": "string",
          "default": "",
          "description": "DevPulse API authentication token (keep secret!)"
        },
        "devpulse.autoScan": {
          "type": "boolean",
          "default": true,
          "description": "Automatically scan files for API risks on open/edit"
        },
        "devpulse.autoScanDelay": {
          "type": "number",
          "default": 2000,
          "minimum": 500,
          "maximum": 10000,
          "description": "Delay in milliseconds before auto-scanning edited files"
        },
        "devpulse.enableInlineRiskIndicators": {
          "type": "boolean",
          "default": true,
          "description": "Show inline risk indicators for API endpoints"
        },
        "devpulse.enableHoverDetails": {
          "type": "boolean",
          "default": true,
          "description": "Show API details on hover"
        },
        "devpulse.riskThreshold": {
          "type": "number",
          "default": 50,
          "minimum": 0,
          "maximum": 100,
          "description": "Minimum risk score to show warnings (0-100)"
        }
      }
    },
    "keybindings": [
      {
        "command": "devpulse.analyzeSelection",
        "key": "ctrl+alt+d",
        "mac": "cmd+alt+d",
        "when": "editorTextFocus"
      },
      {
        "command": "devpulse.scanFile",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d",
        "when": "editorTextFocus"
      },
      {
        "command": "devpulse.showDashboard",
        "key": "ctrl+alt+shift+d",
        "mac": "cmd+alt+shift+d"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p ./",
    "watch": "tsc -w -p ./",
    "package": "vsce package",
    "publish:vsce": "vsce publish",
    "prepublishOnly": "npm run build",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.16.5",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.6.2",
    "typescript": "^5.8.3"
  }
}
