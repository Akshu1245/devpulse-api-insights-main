# Supabase (required for AgentGuard features)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key
# Alias supported by the client:
# VITE_SUPABASE_ANON_KEY=your-anon-publishable-key

# FastAPI backend (API security scanner, LLM usage, compliance)
VITE_API_BASE_URL=http://localhost:8000

# Comma-separated origins allowed by Supabase Edge Functions (required for custom domain)
# Example: APP_ALLOWED_ORIGINS=https://devpluse.in,https://www.devpluse.in,http://localhost:5173
APP_ALLOWED_ORIGINS=

# Upstash Redis (recommended for production - shared rate limiting across api-proxy instances)
# Create a Redis DB at https://console.upstash.com/ and add to Supabase secrets:
# supabase secrets set UPSTASH_REDIS_REST_URL=... UPSTASH_REDIS_REST_TOKEN=...
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Encryption secret for secure API key storage (Supabase Edge Functions)
# Set this in Supabase secrets (do NOT commit):
# supabase secrets set KEY_ENCRYPTION_SECRET="a-long-random-secret"
